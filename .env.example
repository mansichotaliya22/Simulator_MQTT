# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.

# Weather data provider API keys
OPENWEATHER_KEY=your_openweathermap_key_here
WEATHERAPI_KEY=your_weatherapi_key_here
TOMORROW_KEY=your_tomorrow_io_key_here

# EMQX broker
MQTT_HOST=localhost
MQTT_PORT=1883

MQTT_PUBLISHER_USER=weather_provider_1
MQTT_PUBLISHER_PASSWORD=wp1_secret

MQTT_SUBSCRIBER_USER=weather_subscriber_1
MQTT_SUBSCRIBER_PASSWORD=ws1_secret

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=weather_fusion
MONGO_COLLECTION_NAME=weather_data
